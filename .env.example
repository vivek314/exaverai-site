# Optional: set to enable real email delivery from the contact form via Resend.
# If unset, submissions are logged server-side and the form still returns success (dev mode).
RESEND_API_KEY=
# Address that contact-form submissions are sent to.
CONTACT_TO_EMAIL=hello@example.com
# Verified Resend sender (must be a domain you own and verified in Resend).
CONTACT_FROM_EMAIL=onboarding@resend.dev
